{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "lib": ["ES2020", "DOM"],
        "paths": {
            "@/*": ["./*"]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowArbitraryExtensions": true,
        "sourceMap": true,
        "noEmit": true
    },
    "include": ["./**/*.ts", "../shared/**/*.ts"],
    "exclude": ["node_modules"]
}
